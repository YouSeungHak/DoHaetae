{
  "name": "dohaetae",
  "version": "0.1.0",
  "description": "AI 수호 생명체 해태 - macOS 바탕화면 AI 캐릭터",
  "main": "./out/main/index.js",
  "author": "DoHaetae",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "active-win": "^8.1.0",
    "openai": "^6.32.0",
    "uiohook-napi": "^1.5.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.dohaetae.app",
    "productName": "DoHaetae",
    "files": [
      "out/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "minimumSystemVersion": "13.0",
      "darkModeSupport": true,
      "extendInfo": {
        "NSAccessibilityUsageDescription": "도해태가 키보드/마우스 입력을 감지하여 막힌 시간을 판단합니다."
      }
    },
    "dmg": {
      "title": "DoHaetae ${version}",
      "background": null,
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
